{
  "name": "shivshakti_technologies",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "db:generate": "npm run db:generate -w backend",
    "db:push": "npm run db:push -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:studio": "npx prisma studio --schema=backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
